  {\n   \"cell_type\": \"code\",\n   \"execution_count\": null,\n   \"id\": \"color_aug_cell\",\n   \"metadata\": {},\n   \"outputs\": [],\n   \"source\": [\n    \"# Cell 2: Color Augmentation\\n\",\n    \"import torchvision.transforms as transforms\\n\",\n    \"import torch\\n\",\n    \"import random\\n\",\n    \"\\n\",\n    \"class ColorAugmentation:\\n\",\n    \"    def __init__(self, hue_range=0.15, saturation_range=0.2, brightness_range=0.2, contrast_range=0.2):\\n\",\n    \"        self.color_jitter = transforms.ColorJitter(\\n\",\n    \"            brightness=brightness_range,\\n\",\n    \"            contrast=contrast_range,\\n\",\n    \"            saturation=saturation_range,\\n\",\n    \"            hue=hue_range\\n\",\n    \"        )\\n\",\n    \"        \\n\",\n    \"    def __call__(self, image):\\n\",\n    \"        if random.random() > 0.5:\\n\",\n    \"            return self.color_jitter(image)\\n\",\n    \"        return image\\n\",\n    \"\\n\",\n    \"class HSVAugmentation:\\n\",\n    \"    def __init__(self, hue_shift=15, sat_shift=20, val_shift=20):\\n\",\n    \"        self.hue_shift = hue_shift\\n\",\n    \"        self.sat_shift = sat_shift\\n\",\n    \"        self.val_shift = val_shift\\n\",\n    \"        \\n\",\n    \"    def __call__(self, image):\\n\",\n    \"        if isinstance(image, torch.Tensor):\\n\",\n    \"            image = transforms.ToPILImage()(image)\\n\",\n    \"            \\n\",\n    \"        hsv = cv2.cvtColor(np.array(image), cv2.COLOR_RGB2HSV).astype(np.float32)\\n\",\n    \"        hsv[:,:,0] += random.uniform(-self.hue_shift, self.hue_shift)\\n\",\n    \"        hsv[:,:,1] *= random.uniform(1-self.sat_shift/100, 1+self.sat_shift/100)\\n\",\n    \"        hsv[:,:,2] *= random.uniform(1-self.val_shift/100, 1+self.val_shift/100)\\n\",\n    \"        hsv[:,:,0] = np.clip(hsv[:,:,0], 0, 179)\\n\",\n    \"        hsv[:,:,1] = np.clip(hsv[:,:,1], 0, 255)\\n\",\n    \"        hsv[:,:,2] = np.clip(hsv[:,:,2], 0, 255)\\n\",\n    \"        rgb = cv2.cvtColor(hsv.astype(np.uint8), cv2.COLOR_HSV2RGB)\\n\",\n    \"        return transforms.ToTensor()(rgb)\\n\",\n    \"\\n\",\n    \"color_aug = ColorAugmentation()\\n\",\n    \"hsv_aug = HSVAugmentation()\\n\",\n    \"print('Color augmentation transforms initialized')\\n\"\n   ]\n  }